# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Public URL for download links (required for large file downloads)
HOST_URL=https://yourdomain.com

# Optional: Token expiration time in minutes (default: 60)
TOKEN_EXPIRATION_MINUTES=60

# Optional: File retention time in hours (default: 2)
FILE_RETENTION_HOURS=2

# Admin Web UI credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production

# Optional: absolute path on the host to a Netscape-format cookies file,
# used by yt-dlp to download videos that require an authenticated session.
# Leave unset to disable.
# COOKIES_FILE_PATH=/path/to/cookies.txt